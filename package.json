{
	"name": "dear-diary",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"dev": "cross-env APP_VARIANT=development EXPO_USE_FAST_RESOLVER=1 expo start --dev-client",
		"android": "cross-env APP_VARIANT=development expo run:android",
		"ios": "cross-env APP_VARIANT=development expo run:ios",
		"web": "expo start --web",
		"test": "jest --watchAll",
		"lint": "expo lint",
		"prebuild:android": "npx expo prebuild -p android --clean",
		"build:dev": "pnpm prebuild:android && pnpm android",
		"build:preview": "eas build -p android --profile preview",
		"build:production": "eas build -p android --profile production"
	},
	"jest": {
		"preset": "jest-expo"
	},
	"dependencies": {
		"@legendapp/state": "^3.0.0-beta.8",
		"@react-navigation/native": "^6.0.2",
		"@supabase/supabase-js": "^2.45.4",
		"aes-js": "^3.1.2",
		"expo": "~51.0.28",
		"expo-build-properties": "~0.12.5",
		"expo-constants": "~16.0.2",
		"expo-dev-client": "~4.0.28",
		"expo-font": "~12.0.9",
		"expo-haptics": "~13.0.1",
		"expo-image": "~1.13.0",
		"expo-image-picker": "~15.0.7",
		"expo-linear-gradient": "~13.0.2",
		"expo-linking": "~6.3.1",
		"expo-router": "~3.5.23",
		"expo-secure-store": "~13.0.2",
		"expo-splash-screen": "~0.27.5",
		"expo-status-bar": "~1.12.1",
		"expo-system-ui": "~3.0.7",
		"expo-web-browser": "~13.0.3",
		"nativewind": "4.0.1",
		"react": "18.2.0",
		"react-native": "0.74.5",
		"react-native-error-boundary": "^1.2.5",
		"react-native-gesture-handler": "~2.16.1",
		"react-native-get-random-values": "~1.11.0",
		"react-native-keyboard-controller": "^1.14.1",
		"react-native-mmkv": "2.12.2",
		"react-native-reanimated": "~3.10.1",
		"react-native-safe-area-context": "4.10.5",
		"react-native-screens": "3.31.1",
		"tailwindcss": "^3.4.13"
	},
	"devDependencies": {
		"@babel/core": "^7.20.0",
		"@biomejs/biome": "1.9.3",
		"@types/jest": "^29.5.12",
		"@types/react": "~18.2.45",
		"@types/react-test-renderer": "^18.0.7",
		"cross-env": "^7.0.3",
		"jest": "^29.2.1",
		"jest-expo": "~51.0.3",
		"react-test-renderer": "18.2.0",
		"reactotron-react-native": "^5.1.9",
		"reactotron-react-native-mmkv": "^0.2.7",
		"typescript": "~5.3.3"
	},
	"private": true,
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"enabled": true
			}
		}
	}
}
